{
  "name": "brahamsbot-backend",
  "version": "1.0.0",
  "description": "Backend API para BrahamsBot",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "tsx src/database/migrate.ts",
    "seed": "tsx src/database/seed.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "express": "^5.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "@whiskeysockets/baileys": "^6.7.9",
    "telegraf": "^4.16.3",
    "groq-sdk": "^0.7.0",
    "zod": "^3.24.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "winston": "^3.17.0",
    "qrcode": "^1.5.4",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "@hapi/boom": "^10.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14"
  }
}
